#
# Ignore file for weewx-Weather34
#

# Runtime-generated JSON cache files (regenerated by WeeWX web services)
jsondata/*

# Runtime-generated server data (generated from .tmpl files by WeeWX)
serverdata/*

# Highcharts generated JSON data
w34highcharts/json/*
w34highcharts/json_day/*

# Personal configuration (contains API keys, station location, etc.)
settings1.php

# Menu extras (user-specific)
menu-extras.php

# Backup files
*.bak

# OS artifacts
.DS_Store
Thumbs.db

# Experimental remnants
*.php1

# Apple compressed file remnants
__MACOSX/

# Python cache
__pycache__/
*.pyc

# Downloaded graphics data
chartswudata/*

# Demo data
demodata/*

# Highcharts third-party libraries (downloaded separately, large binaries)
w34highcharts/scripts/highstock.js
w34highcharts/scripts/highcharts-more.js
w34highcharts/scripts/boost.js
w34highcharts/scripts/exporting.js
w34highcharts/scripts/windbarb.js

# Daylight map (optional feature)
daylightmap/*
